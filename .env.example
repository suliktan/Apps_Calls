# ══════════════════════════════════════════
#  Agora
# ══════════════════════════════════════════
AGORA_APP_ID=ВАШ_APP_ID
AGORA_APP_CERTIFICATE=ВАШ_APP_CERTIFICATE
TOKEN_EXPIRE_SECONDS=3600

# ══════════════════════════════════════════
#  PostgreSQL
# ══════════════════════════════════════════
POSTGRES_DB=calls_db
POSTGRES_USER=calls_user
POSTGRES_PASSWORD=ПРИДУМАЙ_СЛОЖНЫЙ_ПАРОЛЬ

# Строка подключения — замени пароль на тот же что выше
DATABASE_URL=postgresql+asyncpg://calls_user:ПРИДУМАЙ_СЛОЖНЫЙ_ПАРОЛЬ@postgres:5432/calls_db

# ══════════════════════════════════════════
#  Redis
# ══════════════════════════════════════════
REDIS_PASSWORD=ПРИДУМАЙ_СЛОЖНЫЙ_ПАРОЛЬ
REDIS_URL=redis://:ПРИДУМАЙ_СЛОЖНЫЙ_ПАРОЛЬ@redis:6379/0

# ══════════════════════════════════════════
#  CORS
# ══════════════════════════════════════════
ALLOWED_ORIGINS=https://calls.akyl-chehsmesi.ru,https://akyl-chehsmesi.ru
